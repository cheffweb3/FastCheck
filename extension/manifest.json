{
  "manifest_version": 3,
  "name": "FastCheck",
  "version": "1.0.0",
  "description": "Real-time fact-checker for memecoin narratives",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "https://axiom.trade/*",
    "https://gmgn.ai/*",
    "https://padre.gg/*",
    "https://trade.padre.gg/*",
    "https://fastcheck-api-production.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["content/twitter.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://axiom.trade/*",
        "https://gmgn.ai/*",
        "https://padre.gg/*",
        "https://trade.padre.gg/*"
      ],
      "js": ["content/terminals.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "32": "assets/icons/icon32.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "icons": {
    "32": "assets/icons/icon32.png",
    "128": "assets/icons/icon128.png"
  }
}